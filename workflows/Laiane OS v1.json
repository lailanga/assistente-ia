    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Pesquisa tarefas do usuário.\n\nUtilize esta ferramenta sempre que o usuário desejar consultar tarefas existentes.\n\nExemplos:\n\n- Quais tarefas tenho?\n- O que preciso fazer?\n- Tenho tarefas pendentes?\n- Quais tarefas estão concluídas?\n- Quais tarefas vencem hoje?\n- Tenho tarefas de estudos?\n- Existe alguma tarefa relacionada ao PostgreSQL?\n\nExtraia apenas os filtros necessários.\n\nSe o usuário pedir todas as tarefas, deixe o parâmetro query vazio.\n\nNunca utilize esta ferramenta para criar, editar, concluir ou excluir tarefas.",
        "operation": "executeQuery",
        "query": "SELECT\n    id,\n    title,\n    description,\n    category,\n    priority,\n    status,\n    due_date,\n    created_at,\n    completed_at\nFROM assistant.tasks\nWHERE user_id = '9fd26861-5532-4349-8a8a-70ffe4dd960d'\nAND (\n    $1 = ''\n    OR title ILIKE '%' || $1 || '%'\n    OR description ILIKE '%' || $1 || '%'\n    OR category ILIKE '%' || $1 || '%'\n)\nORDER BY\nCASE\n    WHEN status = 'PENDING' THEN 1\n    WHEN status = 'COMPLETED' THEN 2\n    ELSE 3\nEND,\npriority DESC,\ndue_date ASC NULLS LAST;",
        "options": {
          "queryReplacement": "={{$fromAI(\n\"query\",\n\"Palavra-chave para localizar tarefas. Se o usuário pedir todas as tarefas, deixe vazio.\"\n)}}"
        }
      },
